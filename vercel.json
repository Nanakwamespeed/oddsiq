{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/ingest",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/predict",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/accuracy",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/newsletter",
      "schedule": "0 7 * * *"
    }
  ]
}
